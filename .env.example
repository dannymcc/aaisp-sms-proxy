SMS_TOKEN=your-secret-token-for-sender-fetcher-and-push-urls
RECEIVE_TOKEN=your-secret-token-for-aaisp-inbound-number-1
RECEIVE_TOKEN_2=your-secret-token-for-aaisp-inbound-number-2

# Add one entry per AAISP number.
# Key format: digits only, no leading + (e.g. 447911000000 for +447911000000)
AAISP_44XXXXXXXXXX_USERNAME=+44XXXXXXXXXX
AAISP_44XXXXXXXXXX_PASSWORD=your-aaisp-outgoing-sms-password

# AAISP_44YYYYYYYYY_USERNAME=+44YYYYYYYYY
# AAISP_44YYYYYYYYY_PASSWORD=your-aaisp-outgoing-sms-password

# Heartbeat: delivers a daily message to Groundwire confirming the server is running.
# Enabled by default. Set to false to disable.
HEARTBEAT_ENABLED=true
# Daytime window (24-hour format). Messages are only sent within this range.
HEARTBEAT_START_HOUR=8
HEARTBEAT_END_HOUR=21
# Target account override (optional). Auto-detected from the first AAISP_*_USERNAME if unset.
# HEARTBEAT_ACCOUNT=+44XXXXXXXXXX
